# AWS Configuration
aws_region    = "us-west-2"
instance_type = "t3.medium"

# Application Secrets (required - replace with your values)
postgres_password = "your-secure-postgres-password"
jwt_base64_secret = "your-base64-encoded-jwt-secret"

# Optional
# key_name        = "flowinquiry-key"
# instance_name   = "flowinquiry-poc"
# git_branch      = "main"
# allowed_ssh_cidr = "YOUR_IP/32"  # Restrict SSH to your IP
